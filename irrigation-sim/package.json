    "@types/react-dom": "18.3.5",
    "@vitejs/plugin-react": "4.3.4",
    "jest": "29.7.0",
    "ts-jest": "29.2.5",
    "ts-node": "10.9.2",
    "typescript": "5.7.3",
    "vite": "6.0.11"
  }
